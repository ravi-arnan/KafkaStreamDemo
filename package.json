{
  "name": "kafka-stream-demo",
  "version": "1.0.0",
  "description": "Apache Kafka Real-Time Log Processing Demo untuk mata kuliah Big Data",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "producer": "node kafka-producer.js",
    "consumer": "node kafka-consumer.js",
    "docker:up": "docker compose up -d",
    "docker:up:tools": "docker compose --profile tools up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "express": "^4.18.2",
    "kafkajs": "^2.2.4",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "kafka",
    "apache-kafka",
    "big-data",
    "streaming",
    "real-time",
    "nodejs",
    "docker"
  ],
  "author": "",
  "license": "MIT"
}
